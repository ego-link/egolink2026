# EgoBench Competition - Environment Configuration
# Copy this file to .env and fill in your API keys.
#   cp .env.example .env
# Then source it before running:
#   source .env

# =============================================================================
# USER AGENT CONFIGURATION
# =============================================================================
# Model used to simulate customer behavior
# Default: Qwen3.5-397B-A17B
export USER_MODEL_NAME="Qwen3.5-397B-A17B"

# API key for user simulation model
export API_KEY="your-user-model-api-key"

# Base URL for user model API endpoint
# Default: https://api.example.com/v1
export LLM_API_BASE_URL="https://your-api-endpoint.com/v1"

# =============================================================================
# SERVICE AGENT CONFIGURATION
# =============================================================================
# Model being evaluated as customer service agent
# Default: Qwen3.5-397B-A17B
export SERVICE_MODEL_NAME="Qwen3.5-397B-A17B"

# API key for service model (optional - defaults to API_KEY if not set)
# export SERVICE_API_KEY="your-service-model-api-key"

# Base URL for service model API endpoint
# For local deployment, set this to your local API endpoint
# export SERVICE_API_BASE_URL="https://your-local-endpoint.com/v1"

# =============================================================================
# VIDEO CONFIGURATION
# =============================================================================
# Video storage mode: "local" or "url"
# "local" - Use videos from the local videos/ folder (default)
# "url" - Use public URLs provided in VIDEO_URL_MAPPING
# export VIDEO_MODE="local"

# Base path for local videos (optional - defaults to ./videos)
# export VIDEO_LOCAL_PATH="./videos"

# Video URL mapping (required if VIDEO_MODE="url")
# Format: JSON string mapping video filenames to public URLs
# Example: export VIDEO_URL_MAPPING='{"retail1.mp4": "https://example.com/videos/retail1.mp4"}'
# export VIDEO_URL_MAPPING='{"retail1.mp4": "https://your-bucket.com/retail1.mp4"}'

# =============================================================================
# OTHER MODELS (Optional - for advanced usage)
# =============================================================================
# Kimi (Moonshot) API key - Used by: kimi-k2.5
# export KIMI_API_KEY="your-kimi-api-key-here"

# Xiaomi MiMo API key - Used by: mimo-v2-omni
# export MIMO_API_KEY="your-mimo-api-key-here"

# Zhipu AI API key - Used by: glm-5v-turbo, glm-4.5v
# export ZHIPU_API_KEY="your-zhipu-api-key-here"